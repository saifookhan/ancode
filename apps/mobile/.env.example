# Copy this file to apps/mobile/assets/.env for local runs (file is gitignored).
# CI (Codemagic) should pass the same values via SUPABASE_URL / SUPABASE_ANON_KEY env vars.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional: shortlink domain for QR/share links
# ANCODE_DOMAIN=ancode.vercel.app
# Optional: enables real AI replies in Chatbot
GEMINI_API_KEY=your-gemini-api-key

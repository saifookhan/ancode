# Copy this file to apps/mobile/assets/.env for local runs (file is gitignored).
# CI / store builds: pass SUPABASE_* and optionally GEMINI_API_KEY via --dart-define=...
# (merged at startup so the chatbot works even when assets/.env is not in the bundle).
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# Optional: shortlink domain for QR/share links
# ANCODE_DOMAIN=ancode.vercel.app
# Optional: enables real AI replies in Chatbot
GEMINI_API_KEY=your-gemini-api-key

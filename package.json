{
  "name": "ancode",
  "private": true,
  "scripts": {
    "supabase": "supabase",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "db:diff": "supabase db diff",
    "db:seed": "supabase db execute -f supabase/seed.sql",
    "db:setup": "supabase db push && supabase db execute -f supabase/seed.sql",
    "start": "supabase start",
    "stop": "supabase stop",
    "studio": "supabase db studio",
    "dev": "cd apps\\web && run_web.bat",
    "dev:debug": "cd apps\\web && run_web.bat debug",
    "dev:fresh": "npm run get:all && npm run dev",
    "run:web": "cd apps\\web && run_web.bat",
    "run:web:debug": "cd apps\\web && run_web.bat debug",
    "run:mobile": "cd apps/mobile && flutter run",
    "get:web": "cd apps/web && flutter pub get",
    "get:mobile": "cd apps/mobile && flutter pub get",
    "get:all": "cd packages/shared && flutter pub get && cd ../../apps/web && flutter pub get && cd ../mobile && flutter pub get"
  },
  "devDependencies": {
    "supabase": "^2.75.0"
  }
}
